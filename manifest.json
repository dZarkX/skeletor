{
  "manifest_version": 3,
  "name": "Skeleton Run",
  "version": "1.0",
  "description": "A silly skeleton that runs across your screen occasionally.",
  "permissions": [
    "alarms",
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Run Skeleton Run!",
    "default_popup": "popup.html"
  },
  "commands": {
    "trigger-skeleton": {
      "suggested_key": {
        "default": "Ctrl+Shift+F10"
      },
      "description": "Trigger skeleton manually (Debug)"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "skeleton_spritesheet.png",
        "sounds/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}